// ── GALLERY ──
function addPhotos(input){
  const grid=document.getElementById('galleryGrid');
  if(grid.querySelector('.g-placeholder'))grid.innerHTML='';
  Array.from(input.files).forEach(file=>{
    const r=new FileReader();
    r.onload=e=>{
      const d=document.createElement('div');d.className='g-item';
      d.innerHTML=`<img src="${e.target.result}" onclick="openLightbox(this.src)"/><button class="remove-photo" onclick="this.parentNode.remove()">✕</button>`;
      grid.appendChild(d);
    };r.readAsDataURL(file);
  });
  showToast(`✅ ${input.files.length} photo(s) added!`);input.value='';
}
function openLightbox(src){document.getElementById('lb-img').src=src;document.getElementById('lightbox').classList.add('open')}
function closeLightbox(){document.getElementById('lightbox').classList.remove('open')}

// ── VIDEOS ──
function getYTId(url){const m=url.match(/(?:v=|youtu\.be\/|embed\/)([a-zA-Z0-9_-]{11})/);return m?m[1]:null}
function addVideo(){
  const inp=document.getElementById('ytInput');const url=inp.value.trim();
  if(!url){showToast('❌ YouTube link paste ചെയ്യൂ!');return;}
  const id=getYTId(url);if(!id){showToast('❌ Valid YouTube link അല്ല');return;}
  const empty=document.getElementById('videoEmpty');if(empty)empty.remove();
  const grid=document.getElementById('videoGrid');
  const w=document.createElement('div');w.className='video-wrapper';
  w.innerHTML=`<iframe src="https://www.youtube.com/embed/${id}" allowfullscreen loading="lazy"></iframe><button class="video-remove" onclick="this.parentNode.remove()">✕ Remove</button>`;
  grid.appendChild(w);inp.value='';showToast('✅ Video added!');
}

